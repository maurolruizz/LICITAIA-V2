# ETAPA G — Fase Interna 3 — Variáveis de ambiente do backend API
#
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser versionado no Git.

# Ambiente de execução (development | staging | production)
NODE_ENV=development

# Porta do servidor HTTP (padrão: 3001)
PORT=3001

# Origem permitida para CORS — obrigatória em staging e production
# CORS_ORIGIN=http://localhost:3000

# URL de conexão com PostgreSQL
# Padrão dev: postgresql://postgres:postgres@localhost:5432/licitaia_dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/licitaia_dev

# Segredo de assinatura JWT — obrigatório em staging e production (mín. 32 chars)
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-este-valor-por-um-segredo-real-de-pelo-menos-32-caracteres

# Validade do access token em segundos (padrão: 900 = 15 min)
JWT_ACCESS_EXPIRES_SECS=900

# Validade da sessão/refresh token em dias (padrão: 7)
JWT_REFRESH_EXPIRES_DAYS=7
